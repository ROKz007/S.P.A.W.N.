# NODE_ENV=production for Render deployment
NODE_ENV=production
# Port (Render/Railway provide a port automatically; keep default for local runs)
PORT=3000

# Supabase server-side credentials
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase client-side anon key (only needed for client-side features)
SUPABASE_KEY=

# JWT secret (server-side only)
JWT_SECRET=

# Enable Socket.IO support on hosting that supports persistent sockets
ENABLE_SOCKETS=true

# Frontend URL (set this to your Vercel URL to whitelist CORS on the backend)
FRONTEND_URL=https://your-app.vercel.app