PORT=3000
# Your Supabase project URL (from Supabase project settings)
SUPABASE_URL=
# Supabase anon/public key (client-side safe)
SUPABASE_KEY=
# Supabase service role key (server-side ONLY) — keep this secret
SUPABASE_SERVICE_ROLE_KEY=
# JWT signing secret (use a long random string)
JWT_SECRET=
# Optional: set to 'true' to enable socket.io (default: enabled in development)
ENABLE_SOCKETS=false